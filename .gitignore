# ========================================================================= #
# Unity Standard-Ignore                                                     #
# ========================================================================= #
.utmp/
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
/[Ex]ternal/
/[尝]ocal[Cc]ache/        # Korrigiert von [尝]ocal[Cc]ache
